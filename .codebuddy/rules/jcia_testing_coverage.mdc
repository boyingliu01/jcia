### 测试命名规范
```python
# ✅ 测试类：Test + 实体/功能名称
class TestChangeSet:
    """ChangeSet测试类."""

# ✅ 测试方法：test_ + 方法/属性名称
def test_changed_files(self) -> None:
    """测试变更文件列表."""

# ✅ 使用描述性名称
def test_empty_change_set_returns_true_for_is_empty(self) -> None:
    """测试空变更集判断."""

# ❌ 避免过于简单的名称
def test_empty(self) -> None:
    pass
```

## 测试模式

### 1. 实体属性测试
```python
def test_full_name_with_signature(self) -> None:
    """测试全限定名包含签名."""
    method_change = MethodChange(
        class_name="Service",
        method_name="method",
        signature="(String)"
    )
    assert method_change.full_name == "com.Service.method(String)"
```

### 2. 属性计算测试
```python
def test_is_java_file(self) -> None:
    """测试是否为Java文件."""
    java_file = FileChange(file_path="src/com/Service.java")
    assert java_file.is_java_file is True
    
    non_java = FileChange(file_path="README.md")
    assert non_java.is_java_file is False
```

### 3. 边界条件测试
```python
def test_empty_change_set(self) -> None:
    """测试空变更集."""
    empty_set = ChangeSet()
    assert empty_set.is_empty() is True
    assert empty_set.total_insertions == 0
    assert empty_set.total_deletions == 0
```

### 4. 集合操作测试
```python
def test_add_file_change(self) -> None:
    """测试添加文件变更."""
    change_set = ChangeSet()
    file_change = FileChange(file_path="Service.java")
    
    change_set.add_file_change(file_change)
    
    assert change_set.total_changes == 1
    assert "Service.java" in change_set.changed_files
```

### 5. 转换方法测试
```python
def test_to_dict(self) -> None:
    """测试转换为字典."""
    change_set = ChangeSet(
        file_changes=[FileChange(file_path="File.java")]
    )
    result_dict = change_set.to_dict()
    
    assert isinstance(result_dict, dict)
    assert "changed_files" in result_dict
```

