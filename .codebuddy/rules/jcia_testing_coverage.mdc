## 异常测试

```python
def test_invalid_input_raises_error(self) -> None:
    """测试无效输入抛出错误."""
    with pytest.raises(AnalysisError) as exc_info:
        analyzer.analyze_commits("")
    
    assert "invalid commit" in str(exc_info.value)
```

## 参数化测试

```python
@pytest.mark.parametrize("file_path,expected", [
    ("Test.java", True),
    ("test.java", True),
    ("Service.java", True),
    ("README.md", False),
    ("pom.xml", False),
])
def test_is_test_file(self, file_path: str, expected: bool) -> None:
    """参数化测试：判断是否为测试文件."""
    file_change = FileChange(file_path=file_path)
    assert file_change.is_test_file == expected
```

