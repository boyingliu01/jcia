## Mock 使用规则

### Mock 适配器
```python
from unittest.mock import Mock
from jcia.core.interfaces.analyzer import ChangeAnalyzer

def test_change_analyzer_mock(self):
    """使用 mock 测试用例."""
    # 创建 mock
    mock_analyzer = Mock(spec=ChangeAnalyzer)
    mock_analyzer.analyze_commits.return_value = ChangeSet()
    
    # 使用 mock
    result = mock_analyzer.analyze_commits("abc123")
    
    # 验证
    mock_analyzer.analyze_commits.assert_called_once_with("abc123")
    assert isinstance(result, ChangeSet)
```

### Mock 仓储
```python
from unittest.mock import Mock
from jcia.core.interfaces.repository import TestRunRepository

def test_with_repository_mock(self):
    """使用仓储 mock 测试用例."""
    mock_repo = Mock(spec=TestRunRepository)
    mock_test_run = TestRun(id=1)
    mock_repo.save.return_value = 1
    
    # 使用 mock
    test_run_id = mock_repo.save(mock_test_run)
    
    # 验证
    assert test_run_id == 1
    mock_repo.save.assert_called_once_with(mock_test_run)
```

