# JCIA 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# ===========================================
# 火山引擎 AI 服务 (可选)
# ===========================================
# 用于 AI 驱动的测试生成功能
VOLCENGINE_ACCESS_KEY=your_access_key_here
VOLCENGINE_SECRET_KEY=your_secret_key_here
VOLCENGINE_APP_ID=your_app_id_here

# ===========================================
# OpenAI API (可选)
# ===========================================
# 用于 OpenAI 驱动的测试生成功能
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# SkyWalking (可选)
# ===========================================
# 用于运行时调用链分析
SKYWALKING_OAP_SERVER=http://localhost:12800
SKYWALKING_API_TOKEN=your_token_here